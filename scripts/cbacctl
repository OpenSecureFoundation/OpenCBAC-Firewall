#!/usr/bin/env bash
set -euo pipefail

APP_DIR="${CBAC_APP_DIR:-/opt/cbac-shield}"
CONF_FILE="${CBAC_CONF_FILE:-/etc/cbac-shield/cbac.conf}"

if [ -f "$CONF_FILE" ]; then
  set -a
  # shellcheck disable=SC1090
  . "$CONF_FILE"
  set +a
fi

export CBAC_CONFIG_DIR="${CBAC_CONFIG_DIR:-/etc/cbac-shield}"
export CBAC_LOG_DIR="${CBAC_LOG_DIR:-/var/log/cbac-shield}"

cd "$APP_DIR"
exec "$APP_DIR/.venv/bin/python" -m app.cli "$@"
